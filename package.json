{
  "name": "@avinashchby/devclean",
  "version": "0.1.1",
  "description": "Developer disk cleanup tool — reclaim hundreds of GB by cleaning node_modules, target, venv, .next, __pycache__, .gradle, and 30+ build artifact types across all languages",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "devclean": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "disk-space",
    "cleanup",
    "cleaner",
    "node_modules",
    "build-artifacts",
    "devtools",
    "developer-tools",
    "cli",
    "node-modules-cleaner",
    "disk-cleanup",
    "free-space",
    "reclaim-space",
    "venv",
    "target",
    "pycache",
    "next",
    "gradle",
    "rust",
    "python",
    "build-cache",
    "dependency-cleaner",
    "project-cleaner",
    "artifact-cleaner",
    "storage",
    "npkill-alternative",
    "kondo-alternative",
    "cross-platform"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
